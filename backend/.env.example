# ============================================================
#  股市監控系統 — 環境變數設定
#  複製此檔案為 .env，填入你的金鑰後存檔
#  位置：stock-monitor/backend/.env
# ============================================================

# ── OpenAI API Key ──────────────────────────────────────────
# 取得方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-key-here...

# ── Email 發送方式（二選一）────────────────────────────────────
#
# 方式 A：Resend HTTP API（推薦用於雲端部署，Railway 等平台）
#   - 免費方案：3,000 封/月
#   - 取得 API Key：https://resend.com → API Keys → Create API Key
#   - 設定後系統優先使用 Resend，忽略 Gmail 設定
#
RESEND_API_KEY=re_...your-resend-key-here...

# 方式 B：Gmail SMTP（僅限本機開發，雲端主機通常封鎖 465/587 port）
#   GMAIL_SENDER：你的 Gmail 地址（用來寄信）
#   GMAIL_APP_PASSWORD：應用程式密碼（不是登入密碼！）
#
#   取得 App Password 步驟：
#     1. 開啟 Google 帳戶 → 安全性
#     2. 確認已開啟「兩步驟驗證」
#     3. 搜尋「應用程式密碼」→ 選擇「郵件」→「Windows 電腦」
#     4. 複製產生的 16 位密碼（格式：xxxx xxxx xxxx xxxx）
#
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── 收件人（每日報告發送到）────────────────────────────────────
REPORT_RECIPIENT=your_email@example.com
REPORT_RECIPIENT_2=optional_second@example.com

# ── 報告時間（台灣時間）──────────────────────────────────────
REPORT_HOUR=17
REPORT_MINUTE=0

# ── Write-endpoint protection ──────────────────────────────
# Requests to POST/DELETE endpoints must include header: X-API-Secret: <hash>
# Set the same value in GitHub Secrets as VITE_API_SECRET
API_SECRET_REPORT=your-report-secret
API_SECRET_STOCK=your-stock-secret
